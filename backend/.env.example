DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Data platform stack (phase 1)
DB_ENGINE=sqlite
# For PostgreSQL + PostGIS:
# DB_ENGINE=postgis
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=vitrine
# POSTGRES_USER=vitrine
# POSTGRES_PASSWORD=vitrine

# Redis + Celery
USE_REDIS_CACHE=false
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_DEFAULT_QUEUE=default

# NGSI-LD central API client
NGSILD_AUTH_URL=https://your-oauth-provider.example.com/oauth/token
NGSILD_CLIENT_ID=your-client-id
NGSILD_CLIENT_SECRET=your-client-secret
# Optional tenant-scoped secrets (recommended when each tenant has its own secret):
# NGSILD_AUTH_URL__TENANT_A=https://your-oauth-provider.example.com/oauth/token
# NGSILD_CLIENT_ID__TENANT_A=your-client-id-for-tenant-a
# NGSILD_CLIENT_SECRET__TENANT_A=secret-for-tenant-a
# NGSILD_CLIENT_SECRET__TENANT_B=secret-for-tenant-b
NGSILD_BASE_URL=https://data.fabrico.stellio.io/ngsi-ld/v1
NGSILD_CONTEXT_LINK=<https://uri.etsi.org/ngsi-ld/v1/ngsi-ld-core-context.jsonld>; rel="http://www.w3.org/ns/json-ld#context"; type="application/ld+json"
# Optional
# NGSILD_TENANT=
# NGSILD_TENANT_HEADER=NGSILD-Tenant
# NGSILD_OAUTH_SCOPE=
# NGSILD_OAUTH_AUDIENCE=
# NGSILD_TIMEOUT_SECONDS=20
# NGSILD_CACHE_TTL_SECONDS=60
