STELLIO_AUTH_URL=https://your-oauth-provider.example.com/oauth/token
STELLIO_CLIENT_ID=your-client-id
STELLIO_CLIENT_SECRET=your-client-secret
STELLIO_API_URL=https://data.fabrico.stellio.io/ngsi-ld/v1/entities?type=TronconDeRoute&limit=5
STELLIO_API_ACCEPT=application/json
# Example: <https://uri.etsi.org/ngsi-ld/v1/ngsi-ld-core-context.jsonld>; rel="http://www.w3.org/ns/json-ld#context"; type="application/ld+json"
# STELLIO_API_LINK=
# STELLIO_API_TENANT=
# STELLIO_API_TENANT_HEADER=NGSILD-Tenant
# Optional when your OAuth provider requires them
# STELLIO_OAUTH_SCOPE=your-scope
# STELLIO_OAUTH_AUDIENCE=your-audience
