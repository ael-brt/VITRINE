<?xml version="1.0" encoding="UTF-8" standalone="yes"?><p:sld xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:p="http://schemas.openxmlformats.org/presentationml/2006/main" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" showMasterPhAnim="0" showMasterSp="1" show="1"><p:cSld name=""><p:spTree><p:nvGrpSpPr><p:cNvPr id="1" name=""></p:cNvPr><p:cNvGrpSpPr/><p:nvPr></p:nvPr></p:nvGrpSpPr><p:grpSpPr bwMode="auto"><a:xfrm><a:off x="0" y="0"></a:off><a:ext cx="0" cy="0"></a:ext><a:chOff x="0" y="0"></a:chOff><a:chExt cx="0" cy="0"></a:chExt></a:xfrm></p:grpSpPr><p:sp><p:nvSpPr><p:cNvPr id="189934915" name="Titre 1"></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"></a:spLocks></p:cNvSpPr><p:nvPr><p:ph type="title"></p:ph></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="454041" y="447645"></a:off><a:ext cx="10896517" cy="625198"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle><a:lvl1pPr><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:defRPr sz="3500" b="1" cap="all"><a:solidFill><a:srgbClr val="EF7757"></a:srgbClr></a:solidFill></a:defRPr></a:lvl1pPr></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="3500" b="1" i="0" u="none" strike="noStrike" cap="all" spc="0"><a:solidFill><a:srgbClr val="EF7757"></a:srgbClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>etape 4 : le déploiement</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="2121489346" name="Espace réservé du texte 15"></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"></a:spLocks></p:cNvSpPr><p:nvPr><p:ph type="body" sz="quarter" idx="12"></p:ph></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="454038" y="1612590"></a:off><a:ext cx="6744592" cy="4309677"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle><a:lvl1pPr marL="0" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr sz="2800"><a:solidFill><a:srgbClr val="EF7757"></a:srgbClr></a:solidFill></a:defRPr></a:lvl1pPr><a:lvl2pPr marL="180000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl2pPr><a:lvl3pPr marL="360000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl3pPr><a:lvl4pPr marL="540000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl4pPr><a:lvl5pPr marL="720000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr sz="1600"><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl5pPr><a:lvl6pPr marL="2286000" indent="0"><a:buFont typeface="Arial"></a:buFont><a:buNone/><a:defRPr></a:defRPr></a:lvl6pPr></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>Cet atelier a pour objectif d&apos;aider les participants à élaborer un </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>plan d&apos;action pour mettre en œuvre concrètement leur cas d&apos;usage</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>. Il peut se dérouler lors de l’étape de déploiement, mais également plus tôt, lorsque les porteurs de projet ont du mal à se projeter dans les prochaines actions du projet à réaliser. À partir des résultats des ateliers précédents, comme les ateliers Lego ou de dessin du cas d’usage, les participants identifient et planifient les étapes nécessaires à la réalisation de leur projet, en tenant compte des dimensions juridique, technique, organisationnelle et politique.</a:t></a:r><a:endParaRPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:cs typeface="Arial"></a:cs></a:endParaRPr></a:p><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>L&apos;atelier se déroule en trois étapes. Tout d&apos;abord, les participants identifient et notent les cinq premières actions qu&apos;ils estiment nécessaires pour démarrer leur projet. Ensuite, ces actions sont organisées sur une </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>frise chronologique </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>qui visualise l&apos;enchaînement idéal des étapes, incluant les actions parallèles et les interconnexions. Enfin, les participants scénarisent différentes manières de réaliser leur projet, en créant </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>trois scénarios qui tiennent compte des contraintes et des opportunités</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>, tout en conservant l&apos;essentiel du projet.</a:t></a:r><a:endParaRPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:cs typeface="Arial"></a:cs></a:endParaRPr></a:p><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>Cet atelier permet de structurer et de prioriser les actions nécessaires à sa mise en œuvre. En visualisant les étapes et en scénarisant différentes approches, les participants peuvent anticiper les obstacles et adapter leur plan en conséquence. De plus, les scénarios développés offrent une base solide pour présenter des options aux décideurs, facilitant ainsi la prise de décision et l&apos;alignement des attentes.</a:t></a:r><a:endParaRPr sz="1100"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="1478478519" name="ZoneTexte 1478478518"></p:cNvPr><p:cNvSpPr txBox="1"></p:cNvSpPr><p:nvPr></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="569619" y="1092422"></a:off><a:ext cx="6515104" cy="366119"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr vertOverflow="overflow" horzOverflow="overflow" vert="horz" wrap="square" lIns="91440" tIns="45720" rIns="91440" bIns="45720" numCol="1" spcCol="0" rtlCol="0" fromWordArt="0" anchor="t" anchorCtr="0" forceAA="0" compatLnSpc="0"><a:spAutoFit/></a:bodyPr><a:lstStyle></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1800" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>Rédiger son plan d’action</a:t></a:r><a:endParaRPr sz="1800" b="1"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="634107581" name="Organigramme : Alternative 634107580"></p:cNvPr><p:cNvSpPr></p:cNvSpPr><p:nvPr></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="7198632" y="4329523"></a:off><a:ext cx="4938195" cy="1600200"></a:ext></a:xfrm><a:prstGeom prst="flowChartAlternateProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:ln w="12700" cap="flat" cmpd="sng" algn="ctr"><a:noFill/><a:prstDash val="solid"></a:prstDash><a:miter lim="800000"></a:miter></a:ln></p:spPr><p:style><a:lnRef idx="2"><a:schemeClr val="accent1"><a:shade val="50000"></a:shade></a:schemeClr></a:lnRef><a:fillRef idx="1"><a:schemeClr val="accent1"></a:schemeClr></a:fillRef><a:effectRef idx="0"><a:schemeClr val="accent1"></a:schemeClr></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="lt1"></a:schemeClr></a:fontRef></p:style><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr sz="1100" i="1"></a:rPr><a:t>Cet atelier a été réalisé par Paris Ouest la Défense, la Ville de Fecamp et la Ville de Paris, lors de la 4ème étape. Les projets se trouvaient à une étape charnière, car ils commençaient à être spécifiés mais avaient du mal à se concrétiser. Les ateliers ont permis de mettre en évidence la chronologie des actions à mener, des plus immédiates au plus lointaines, ainsi que les différents jalons à mettre en place. Ils ont également permis de faire le tri entre ce qui était souhaitable et ce qui était réalisable, en priorisant les actions vraiment indispensables.</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="39149060" name="Rectangle 39149059"></p:cNvPr><p:cNvSpPr></p:cNvSpPr><p:nvPr></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="517857" y="5521739"></a:off><a:ext cx="2427313" cy="400529"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:style><a:lnRef idx="2"><a:schemeClr val="accent1"><a:shade val="50000"></a:shade></a:schemeClr></a:lnRef><a:fillRef idx="1"><a:schemeClr val="accent1"></a:schemeClr></a:fillRef><a:effectRef idx="0"><a:schemeClr val="accent1"></a:schemeClr></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="lt1"></a:schemeClr></a:fontRef></p:style><p:txBody><a:bodyPr vertOverflow="overflow" horzOverflow="overflow" vert="horz" wrap="square" lIns="91440" tIns="45720" rIns="91440" bIns="45720" numCol="1" spcCol="0" rtlCol="0" fromWordArt="0" anchor="ctr" anchorCtr="0" forceAA="0" compatLnSpc="0"></a:bodyPr><a:lstStyle></a:lstStyle><a:p><a:pPr algn="ctr"><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr sz="1400" i="1"></a:rPr><a:t>Lien vers le guide d’atelier</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p></p:txBody></p:sp><p:pic><p:nvPicPr><p:cNvPr id="307444413" name="Image 307444412"></p:cNvPr><p:cNvPicPr><a:picLocks noChangeAspect="1"></a:picLocks></p:cNvPicPr><p:nvPr></p:nvPr></p:nvPicPr><p:blipFill><a:blip r:embed="rId3"></a:blip><a:stretch></a:stretch></p:blipFill><p:spPr bwMode="auto"><a:xfrm><a:off x="7579496" y="1755464"></a:off><a:ext cx="4267221" cy="2246063"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr></p:pic></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice xmlns:p159="http://schemas.microsoft.com/office/powerpoint/2015/09/main" xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" Requires="p159"><p:transition p14:dur="2000" advClick="1"></p:transition></mc:Choice><mc:Fallback><p:transition advClick="1"></p:transition></mc:Fallback></mc:AlternateContent></p:sld>