t" anchorCtr="0" forceAA="0" compatLnSpc="0"><a:spAutoFit/></a:bodyPr><a:lstStyle></a:lstStyle><a:p><a:pPr algn="l"><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1400" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>3. Intégration de la donnée dans une plateforme</a:t></a:r><a:endParaRPr sz="1400" b="1"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="781378829" name="Espace réservé du texte 13"></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"></a:spLocks></p:cNvSpPr><p:nvPr><p:ph type="body" sz="quarter" idx="11" hasCustomPrompt="1"></p:ph></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="8185968" y="6211557"></a:off><a:ext cx="3053920" cy="318957"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle><a:lvl1pPr marL="0" indent="0" algn="r"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:spcBef><a:spcPts val="0"></a:spcPts></a:spcBef><a:buNone/><a:defRPr sz="1200"><a:solidFill><a:srgbClr val="EF7757"></a:srgbClr></a:solidFill></a:defRPr></a:lvl1pPr><a:lvl2pPr marL="457200" indent="0"><a:buNone/><a:defRPr></a:defRPr></a:lvl2pPr><a:lvl3pPr marL="914400" indent="0"><a:buNone/><a:defRPr></a:defRPr></a:lvl3pPr><a:lvl4pPr marL="1371600" indent="0"><a:buNone/><a:defRPr></a:defRPr></a:lvl4pPr><a:lvl5pPr marL="1828800" indent="0"><a:buNone/><a:defRPr></a:defRPr></a:lvl5pPr></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:endParaRPr></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="945409457" name="Espace réservé du texte 15"></p:cNvPr><p:cNvSpPr><a:spLocks noGrp="1"></a:spLocks></p:cNvSpPr><p:nvPr><p:ph type="body" sz="quarter" idx="12"></p:ph></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="348208" y="1612593"></a:off><a:ext cx="5536271" cy="3811823"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle><a:lvl1pPr marL="0" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr sz="2800"><a:solidFill><a:srgbClr val="EF7757"></a:srgbClr></a:solidFill></a:defRPr></a:lvl1pPr><a:lvl2pPr marL="180000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl2pPr><a:lvl3pPr marL="360000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl3pPr><a:lvl4pPr marL="540000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl4pPr><a:lvl5pPr marL="720000" indent="0"><a:lnSpc><a:spcPct val="100000"></a:spcPct></a:lnSpc><a:buNone/><a:defRPr sz="1600"><a:solidFill><a:srgbClr val="292574"></a:srgbClr></a:solidFill></a:defRPr></a:lvl5pPr><a:lvl6pPr marL="2286000" indent="0"><a:buFont typeface="Arial"></a:buFont><a:buNone/><a:defRPr></a:defRPr></a:lvl6pPr></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>L’intégration des données est la phase concrète de mise en circulation des flux de données identifiés. Elle consiste à </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1600" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>configurer un ETL</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t> (Extract – Transform – Load) pour</a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1600" b="1" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t> récupérer les données depuis leurs sources </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>(fichiers plats, API, bases de données…), les nettoyer, les transformer selon le modèle sémantique, et les injecter dans une plateforme technique (dans notre cas un context broker). </a:t></a:r><a:endParaRPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:cs typeface="Arial"></a:cs></a:endParaRPr></a:p><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>Ce travail est réalisé par un profil technique de type data engineer, qui configure le pipeline d’intégration, assure la conversion des formats (notamment en JSON-LD pour la compatibilité avec le standard NGSI-LD) et vérifie la cohérence des données.</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr lang="fr-FR" sz="1600" b="0" i="0" u="none" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs></a:rPr><a:t>Cette phase est souvent itérative : les premiers tests d&apos;intégration peuvent révéler des problèmes de format, de jointure ou d’incomplétude, qu’il faut corriger avec les métiers.</a:t></a:r><a:endParaRPr sz="1600"><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="146330397" name="Organigramme : Alternative 146330396"></p:cNvPr><p:cNvSpPr></p:cNvSpPr><p:nvPr></p:nvPr></p:nvSpPr><p:spPr bwMode="auto"><a:xfrm><a:off x="5960583" y="3690767"></a:off><a:ext cx="6064249" cy="2330343"></a:ext></a:xfrm><a:prstGeom prst="flowChartAlternateProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent2"></a:schemeClr></a:solidFill><a:ln w="12700" cap="flat" cmpd="sng" algn="ctr"><a:noFill/><a:prstDash val="solid"></a:prstDash><a:miter lim="800000"></a:miter></a:ln></p:spPr><p:style><a:lnRef idx="2"><a:schemeClr val="accent1"><a:shade val="50000"></a:shade></a:schemeClr></a:lnRef><a:fillRef idx="1"><a:schemeClr val="accent1"></a:schemeClr></a:fillRef><a:effectRef idx="0"><a:schemeClr val="accent1"></a:schemeClr></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="lt1"></a:schemeClr></a:fontRef></p:style><p:txBody><a:bodyPr></a:bodyPr><a:lstStyle></a:lstStyle><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr sz="1200" i="1"></a:rPr><a:t>Le schéma ci-dessus représente le flux utilisé pour l’intégration des données de consommation énergétique avec l’outil open source Nifi, qui fait partie du bac de prototypage.</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p><a:p><a:pPr><a:defRPr></a:defRPr></a:pPr><a:r><a:rPr sz="1200" i="1"></a:rPr><a:t>Chaque « carré » est un processus qui fait une tâche en particulier : le premier appelle les données de l’API : </a:t></a:r><a:r><a:rPr lang="fr-FR" sz="1200" b="0" i="1" u="sng" strike="noStrike" cap="none" spc="0"><a:solidFill><a:schemeClr val="lt1"></a:schemeClr></a:solidFill><a:latin typeface="Arial"></a:latin><a:ea typeface="Arial"></a:ea><a:cs typeface="Arial"></a:cs><a:hlinkClick r:id="rId3" tooltip="https://www.agenceore.fr/opendata/consommation-annuelle-delectricite-et-gaz-par-iris."></a:hlinkClick></a:rPr><a:t>https://www.agenceore.fr/opendata/consommation-annuelle-delectricite-et-gaz-par-iris.</a:t></a:r><a:r><a:rPr sz="1200" i="1"></a:rPr><a:t> Puis, différentes transformations sont appliquées : transformation en json, contextualisation, déclaration des entités et des propriétés, pour au final aboutir au fichier JSON-LD qui répond au standard NGSI-LD, qui est envoyé dans le context broker. Le même travail est fait avec les autres sources de données.</a:t></a:r><a:endParaRPr></a:endParaRPr></a:p></p:txBody></p:sp><p:pic><p:nvPicPr><p:cNvPr id="2043922654" name="Image 2043922653"></p:cNvPr><p:cNvPicPr><a:picLocks noChangeAspect="1"></a:picLocks></p:cNvPicPr><p:nvPr></p:nvPr></p:nvPicPr><p:blipFill><a:blip r:embed="rId4"></a:blip><a:stretch></a:stretch></p:blipFill><p:spPr bwMode="auto"><a:xfrm><a:off x="7374578" y="311934"></a:off><a:ext cx="4388578" cy="3280833"></a:ext></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr></p:pic></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr><mc:AlternateContent xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"><mc:Choice xmlns:p159="http://schemas.microsoft.com/office/powerpoint/2015/09/main" xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" Requires="p159"><p:transition p14:dur="2000" advClick="1"></p:transition></mc:Choice><mc:Fallback><p:transition advClick="1"></p:transition></mc:Fallback></mc:AlternateContent></p:sld>